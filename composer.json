{
    "name": "bcc/disputes",
    "description": "Community dispute system for BCC trust votes.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "BCC\\Disputes\\": "app/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    }
}
